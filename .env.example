DB_PASSWORD=random string
JWT_SECRET=32bit string
# false for local HTTP development; must be true (or unset) in production over HTTPS
COOKIE_SECURE=false
# frontend origin allowed by CORS; http://localhost:5173 for local dev, your Vercel URL in production
CORS_ALLOWED_ORIGIN=http://localhost:5173
# Lax for local dev; None when frontend/backend are on different domains (e.g. Vercel + Fly.io) - requires COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax